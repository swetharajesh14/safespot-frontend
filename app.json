{
  "expo": {
    "name": "SafeSpot",
    "slug": "safespot",
    "scheme": "safespot",
    "version": "1.0.0",
    "jsEngine": "hermes",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.safespot.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "SafeSpot needs your location to keep your Kin updated.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "SafeSpot protects you even when the app is closed.",
        "UIBackgroundModes": [
          "location",
          "fetch"
        ],
        "UIRequiredDeviceCapabilities": [
          "location",
          "fetch"
        ],
        "NSContactsUsageDescription": "SafeSpot needs access to send safety alerts to emergency contacts."
      }
    },
    "android": {
      "package": "com.safespot.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "versionCode": 1,
      "permissions": [
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "SEND_SMS",
        "CALL_PHONE",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "WAKE_LOCK",
        "READ_CONTACTS",
        "READ_PHONE_STATE"
      ],
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@maplibre/maplibre-react-native"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "98bb30ee-82e9-41ad-960e-a5e286026057"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/98bb30ee-82e9-41ad-960e-a5e286026057"
    }
  }
}
